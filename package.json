{
  "name": "url-shortening-and-analysing",
  "version": "1.0.0",
  "description": "Root package for running frontend and backend concurrently",
  "private": true,
  "scripts": {
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:backend": "npm run dev --prefix backend",
